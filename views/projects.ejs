<% layout('layouts/boilerplate') %>

  <section id="projects" class="projects-section reveal">
    <div class="section-inner">

      <div class="section-text">
        <h2 class="section-title">Projects</h2>
        <p class="section-subtitle">
          A selection of projects where I focused on clean architecture,
          scalability, and real-world impact.
        </p>
      </div>

      <div class="projects-grid">
        <!-- Project 1 -->
        <div class="project-row">
          <div class="project-left">
            <span class="project-number">01</span>
          </div>

          <div class="project-info">
            <h3 class="project-title">CardioVision</h3>

            <p class="project-desc">
              Deployed an end-to-end clinical AI pipeline for automated detection and instance segmentation of coronary artery stenosis from angiography images, addressing the bottleneck of manual expert review in cardiology diagnostics.
            </p>

            <p class="project-tech">
              <span>Stack: </span>Python <b>·</b> YOLOv8 <b>·</b> OpenCV <b>·</b> Grad-CAM <b>·</b> Deep Learning <b>·</b> Computer Vision
            </p>

            <div class="project-links">
              <a href="https://github.com/nivijha/CardioVision" target="_blank" aria-label="GitHub">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.54-3.87-1.54-.53-1.36-1.29-1.72-1.29-1.72-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.95.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.27-5.23-5.65 0-1.25.45-2.27 1.19-3.07-.12-.29-.52-1.47.11-3.07 0 0 .97-.31 3.18 1.17.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.48 3.18-1.17 3.18-1.17.63 1.6.23 2.78.11 3.07.74.8 1.19 1.82 1.19 3.07 0 4.39-2.69 5.36-5.25 5.64.41.36.77 1.07.77 2.16v3.2c0 .31.21.68.8.56A11.51 11.51 0 0023.5 12C23.5 5.73 18.27.5 12 .5z" />
                </svg>
              </a>
              <a href="https://cardio-vision-murex.vercel.app/" target="_blank" aria-label="Live Demo">
                <svg viewBox="0 0 24 24">
                  <path d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3z" />
                  <path d="M5 5h6v2H7v10h10v-4h2v6H5z" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Project 2 -->
        <div class="project-row">
          <div class="project-left">
            <span class="project-number">02</span>
          </div>

          <div class="project-info">
            <h3 class="project-title">AWS Product Review Analyzer</h3>

            <p class="project-desc">
              Designed a serverless sentiment analysis pipeline using AWS Lambda, API Gateway, and Comprehend.
              The app ingests review data, detects sentiment and key phrases, and stores results in DynamoDB for real-time analytics.
            </p>

            <p class="project-tech">
              <span>Stack: </span>React.js <b>·</b> Node.js <b>·</b> AWS Lambda <b>·</b> AWS Comprehend <b>·</b> DynamoDB
            </p>

            <div class="project-links">
              <a href="https://github.com/nivijha/aws-product-review-analyzer" target="_blank" aria-label="GitHub">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.54-3.87-1.54-.53-1.36-1.29-1.72-1.29-1.72-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.95.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.27-5.23-5.65 0-1.25.45-2.27 1.19-3.07-.12-.29-.52-1.47.11-3.07 0 0 .97-.31 3.18 1.17.92-.26 1.9-.39 2.88-.39s1.96.13 2.88.39c2.2-1.48 3.18-1.17 3.18-1.17.63 1.6.23 2.78.11 3.07.74.8 1.19 1.82 1.19 3.07 0 4.39-2.69 5.36-5.25 5.64.41.36.77 1.07.77 2.16v3.2c0 .31.21.68.8.56A11.51 11.51 0 0023.5 12C23.5 5.73 18.27.5 12 .5z" />
                </svg>
              </a>
            </div>

          </div>
        </div>

        <!-- Project 3 -->
        <div class="project-row">
          <div class="project-left">
            <span class="project-number">03</span>
          </div>

          <div class="project-info">
            <h3 class="project-title">MedTracker</h3>

            <p class="project-desc">
              Built a secure healthcare dashboard that manages patient records, prescriptions, and appointments.
              Integrated LLaMA-powered entity extraction to summarize medical PDFs and improve clinician workflows.
            </p>

            <p class="project-tech">
              <span>Stack: </span>Next.js <b>·</b> Node.js <b>·</b> Express <b>·</b> MongoDB <b>·</b> JWT <b>·</b> LLaMA
            </p>

