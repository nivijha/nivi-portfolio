<% layout('layouts/boilerplate') %>

  <section id="about" class="about-section reveal">
    <div class="section-inner">
      <div class="about-content">

        <h2 class="section-title">About</h2>

        <p class="about-subtitle">
          I’m a computer science undergraduate focused on backend systems,
          automation, and what happens after code ships to production.
        </p>

        <p class="about-text">
          Work stays close to the problem: designing APIs with clear contracts,
          tracing data flow across services, and handling edge cases instead of
          hiding them behind abstractions.
        </p>

        <p class="about-text">
          Currently looking for early-career roles involving real systems,
          correctness, and long-term maintainability.
        </p>

        <p class="about-principle">
          I care about correctness first, clarity second, and scale when it matters.
        </p>

        <!-- CAREER -->
        <section class="career-wrapper">
          <h3 class="career-title">Career</h3>

          <div class="career-tabs">
            <button class="career-tab active" data-tab="education">Education</button>
            <button class="career-tab" data-tab="experience">Experience</button>
          </div>

          <!-- EDUCATION -->
          <div class="career-tab-panel active" data-panel="education">
            <div class="edu-card">
              <div class="edu-header">
                <div class="edu-icon-wrap">
                  <i data-lucide="book-open"></i>
                </div>
                <div class="edu-header-text">
                  <h5 class="edu-degree">B.Tech — Computer Science & Engineering</h5>
                  <div class="edu-university">Jaypee University of Information Technology</div>
                </div>
              </div>

              <div class="edu-details">
                <div class="edu-detail">
                  <span class="edu-detail-label">Location</span>
                  <span class="edu-detail-value">Solan, IN</span>
                </div>
                <div class="edu-detail">
                  <span class="edu-detail-label">Duration</span>
                  <span class="edu-detail-value">Jul 2023 – Present</span>
                </div>
              </div>

              <div class="edu-cgpa-card">
                <div class="edu-cgpa-text">
                  <span class="edu-cgpa-label">Academic Performance</span>
                  <span class="edu-cgpa-value">CGPA: 8.5/10.0</span>
                </div>
                <div class="edu-cgpa-icon">
                  <i data-lucide="graduation-cap"></i>
                </div>
              </div>

              <div class="edu-coursework">
                <h6 class="edu-coursework-title">Relevant Coursework</h6>
                <div class="edu-coursework-grid">
                  <span class="edu-coursework-tag">Data Structures and Algorithms</span>
                  <span class="edu-coursework-tag">Operating Systems</span>
                  <span class="edu-coursework-tag">Computer Networks</span>
                  <span class="edu-coursework-tag">Object Oriented Programming</span>
                  <span class="edu-coursework-tag">Database Management Systems</span>
                  <span class="edu-coursework-tag">Machine Learning</span>
                  <span class="edu-coursework-tag">Web Technology</span>
                </div>
              </div>
            </div>

            <div class="edu-achievements">
              <h6 class="edu-achievements-title">Achievements & Leadership</h6>
              <div class="edu-achievements-grid">
                <div class="edu-achievement-card">
                  <span class="edu-achievement-number">1574</span>
                  <span class="edu-achievement-label">LEETCODE</span>
                  <span class="edu-achievement-desc">Contest Rating</span>
                </div>
                <div class="edu-achievement-card">
                  <span class="edu-achievement-number">1</span>
                  <span class="edu-achievement-label">LEADERSHIP</span>
                  <span class="edu-achievement-desc">Web Development Team Lead</span>
                </div>
              </div>
            </div>
          </div>

          <!-- EXPERIENCE -->
          <div class="career-tab-panel" data-panel="experience">
            <div class="career-numbered-list">
              <div class="career-numbered-item">
                <span class="career-number">1</span>
                <div class="timeline-content">
                  <span class="timeline-label">Jun 2025 – Jul 2025</span>
                  <h5 class="career-role">Summer Intern — IIT Delhi</h5>
                  <div class="career-meta">Delhi, India</div>
                  <p class="career-desc">
                    Gained hands-on experience in network automation and Linux system management, working with Python,
                    REST APIs, Git, and Docker. Developed automation tools including a Linux System Monitor for resource
                    usage logging and a Security Monitoring Agent to track user and USB activities using multi-threading
                    and event forwarding.
                  </p>
                </div>
              </div>
              <div class="career-numbered-item">
                <span class="career-number">2</span>
                <div class="timeline-content">
                  <span class="timeline-label">Jun 2026 – Present</span>
                  <h5 class="career-role">SDE Intern — Algowire Trading Technologies Pvt. Ltd.</h5>
                  <div class="career-meta">Remote</div>
                  <p class="career-desc">
                    Currently gaining industry experience as a Software Development Intern, working on real-world products and collaborating with engineers to design, build, and improve scalable applications. This role allows me to strengthen my full-stack development skills while contributing to impactful software solutions.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>