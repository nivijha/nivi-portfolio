<% layout('layouts/boilerplate') %>

  <section id="skills" class="skills-section reveal">
    <div class="section-inner">
      <div class="section-text">
        <h2 class="section-title">Technical Skills</h2>
        <p class="section-subtitle">
          Core technologies I use to build full-stack, cloud-native, and ML-enabled products.
        </p>
      </div>

      <div class="skills-columns">

        <!-- Programming -->
        <div class="skills-col">
          <h3>Programming</h3>
          <ul>
            <li>Python</li>
            <li>Core Java</li>
            <li>C</li>
            <li>C++</li>
            <li>JavaScript</li>
          </ul>
        </div>
        
        <!-- Web & Backend -->
        <div class="skills-col">
          <h3>Web & Backend</h3>
          <ul>
            <li>Node.js</li>
            <li>Express.js</li>
            <li>React.js</li>
            <li>REST APIs</li>
          </ul>
        </div>

        <!-- Databases -->
        <div class="skills-col">
          <h3>Databases</h3>
          <ul>
            <li>MongoDB</li>
            <li>MySQL</li>
            <li>DynamoDB</li>
          </ul>
        </div>

        <!-- Systems & Tools -->
        <div class="skills-col">
          <h3>Systems & Tools</h3>
          <ul>
            <li>Docker</li>
            <li>Linux</li>
            <li>Git</li>
            <li>GitHub</li>
          </ul>
        </div>

        <!-- ML & AI -->
        <div class="skills-col">
          <h3>ML & AI</h3>
          <ul>
            <li>NumPy</li>
            <li>Pandas</li>
            <li>PyTorch</li>
            <li>FastAPI</li>
            <li>YOLOv8</li>
            <li>OpenCV</li>
            <li>Grad-CAM</li>
          </ul>
        </div>

        <!-- Cloud Platform -->
        <div class="skills-col">
          <h3>Cloud Platform</h3>
          <ul>
            <li>AWS Lambda</li>
            <li>AWS Comprehend</li>
          </ul>
        </div>
      </div>

      <div class="stack-side-list">

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/react.svg" alt="React">
        </div>

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/nodejs-icon.svg" alt="Node.js">
        </div>

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/python.svg" alt="Python">
        </div>

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/opencv.svg" alt="OpenCV">
        </div>

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/numpy.svg" alt="NumPy">
        </div>

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/aws.svg" alt="AWS">
        </div>

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/docker-icon.svg" alt="Docker">
        </div>

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/mongodb-icon.svg" alt="MongoDB">
        </div>

        <div class="stack-side-item">
          <img src="https://api.iconify.design/logos/linux-tux.svg" alt="Linux">
        </div>
      </div>

  </section>